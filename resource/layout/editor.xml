<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".EditorActivity">

    <!-- App Bar with enhanced design -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:titleTextColor="@color/on_surface"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:navigationIconTint="@color/on_surface"
            app:layout_scrollFlags="scroll|enterAlways" />

        <!-- Enhanced Tab Layout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabIndicatorColor="@color/primary"
            app:tabIndicatorHeight="3dp"
            app:tabIndicatorAnimationMode="elastic"
            app:tabSelectedTextColor="@color/primary"
            app:tabTextColor="@color/secondary_text"
            app:tabRippleColor="@color/primary_container"
            app:tabIndicatorFullWidth="false"
            app:tabTextAppearance="@style/TextAppearance.Material3.LabelMedium" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- File Tree Sidebar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_file_tree"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
                                app:strokeColor="@color/outline"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- File Tree Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@color/surface">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/icon_folder_round"
                        app:tint="@color/primary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/text_project_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Project Files"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                        android:textColor="@color/on_surface"
                        android:ellipsize="end"
                        android:maxLines="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_toggle_file_tree"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:minWidth="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:icon="@drawable/icon_chevron_left_round"
                        app:iconSize="16dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:cornerRadius="16dp"
                        android:contentDescription="Toggle file tree"
                        style="@style/Widget.Material3.Button.TextButton.Icon" />

                </LinearLayout>

                <!-- File Tree Content -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_file_tree"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    android:scrollbars="vertical" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Main Editor Area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- ViewPager for Tab Content -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </LinearLayout>

    </LinearLayout>

    <!-- Floating Action Button for Quick Actions -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_run_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Run code"
        app:srcCompat="@drawable/icon_play_arrow_round"
        app:backgroundTint="@color/secondary"
        app:tint="@color/on_secondary" />

    <!-- Bottom Sheet for AI Actions -->
    <include
        layout="@layout/bottom_sheet_ai_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>